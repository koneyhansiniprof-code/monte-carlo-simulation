#include <iostream>
#include <vector>
#include <random>
#include <cmath>
#include <algorithm>
#include <iomanip>

using namespace std;

int main() {
    double spot = 100, strike = 105, barrier = 160, rate = 0.05, time = 1.0;
    int paths = 1000;
    vector<double> payoffs;
    int choice = 0;

    random_device rd;
    mt19937 gen(rd());

    while (choice != 5) {
        cout << "\n======================================";
        cout << "\n   DERIVATIVE PRICING ENGINE";
        cout << "\n======================================";
        cout << "\n1. Set Parameters Manually";
        cout << "\n2. Randomize Market Conditions";
        cout << "\n3. Run Monte Carlo Simulation";
        cout << "\n4. View Distribution Report";
        cout << "\n5. Exit";
        cout << "\n>> ";
        cin >> choice;

        if (choice == 1) {
            cout << "Enter Spot Price: ";    cin >> spot;
            cout << "Enter Strike Price: ";  cin >> strike;
            cout << "Enter Barrier: ";       cin >> barrier;
            cout << "Enter Risk-Free Rate: "; cin >> rate;
            cout << "Enter Years: ";         cin >> time;
            cout << "Enter Path Count: ";    cin >> paths;
        } 

        else if (choice == 2) {
            uniform_real_distribution<double> d_spot(80, 120);
            uniform_real_distribution<double> d_rate(0.01, 0.08);
            
            spot = d_spot(gen);
            strike = spot * 1.05; 
            barrier = spot * 1.50; 
            rate = d_rate(gen);
            time = 1.0;
            paths = 5000;

            cout << "\n[RANDOMIZED SETTINGS]";
            cout << "\nSpot: " << spot << "\nStrike: " << strike << "\nRate: " << rate;
        }

        else if (choice == 3) {
            payoffs.clear();
            payoffs.reserve(paths);

            const int STEPS = 252;
            const double dt = time / STEPS;
            normal_distribution<double> norm(0.0, 1.0);
            uniform_real_distribution<double> uni(0.0, 1.0);

            cout << "Simulating paths...";

            for (int i = 0; i < paths; ++i) {
                double current_s = spot;
                bool knocked_out = false;
                int regime = 0; 

                for (int t = 0; t < STEPS; ++t) {
                    
                    if (uni(gen) > 0.98) regime = 1 - regime;
                    double vol = (regime == 0) ? 0.15 : 0.35;

                    
                    current_s *= exp((rate - 0.5 * vol * vol) * dt + vol * sqrt(dt) * norm(gen));

                    
                    if (uni(gen) < 0.1 * dt) current_s *= exp(-0.15 + 0.1 * norm(gen));

                    
                    if (current_s >= barrier) { knocked_out = true; break; }
                }
                
                double result = (!knocked_out && current_s > strike) ? (current_s - strike) : 0.0;
                payoffs.push_back(result);
            }
            cout << " Done!";
        }
        else if (choice == 4) {
            if (payoffs.empty()) { cout << "\nError: Run simulation first!"; continue; }
            
            sort(payoffs.begin(), payoffs.end());
            double total_sum = 0;

            cout << "\n--- PAYOFF HISTOGRAM ---\n";
            double max_val = payoffs.back();
            double bin_width = (max_val <= 0) ? 1.0 : max_val / 10;

            for (int b = 0; b < 10; ++b) {
                double low = b * bin_width;
                double high = (b + 1) * bin_width;
                int count = 0;

                for (double p : payoffs) {
                    if (p >= low && p < high) count++;
                    if (b == 0) total_sum = 0; // Reset sum on first bin for fresh calc
                }

                cout << fixed << setprecision(1) << setw(5) << low << " | ";
                int bar_size = (count * 40) / paths;
                for (int j = 0; j < bar_size; ++j) cout << "X";
                cout << " (" << count << ")\n";
            }

            for (double p : payoffs) total_sum += p;
            double fair_value = (total_sum / paths) * exp(-rate * time);

            cout << "--------------------------------------";
            cout << "\nFAIR VALUE PRICE: $" << fixed << setprecision(4) << fair_value;
            cout << "\n--------------------------------------\n";
        }
    }

    return 0;
}

    
